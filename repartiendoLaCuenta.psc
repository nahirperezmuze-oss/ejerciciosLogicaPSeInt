Algoritmo repartiendoLaCuenta
	Definir costoTotal , cantidadPersonas , pagoPorPersona Como Real
	Escribir "Ingresar el costo total de la cena"
	Leer costoTotal
	Escribir "Ingresar la cantidad de personas"
	Leer cantidadPersonas
	pagoPorPersona = costoTotal / cantidadPersonas
	Escribir "Cada persona debe pagar $", pagoPorPersona
FinAlgoritmo
